#header
  margin: 0 auto 2rem
  width: 100%

  h1, .h1
    margin-top: 0
    margin-bottom: 0
    color: $color-text
    letter-spacing: .01em
    font-weight: 700
    font-style: normal
    font-size: 1.5rem
    line-height: 2rem

    antialias()

  a
    background: none
    color: inherit
    text-decoration: none

  #logo
    display: inline-block
    float: left
    margin-right: 20px
    width: $logo-width
    height: $logo-height
    border-radius: 5px
    background-size: $logo-width $logo-height
    background-repeat: no-repeat
    if $logo-grayout
      filter: grayscale(100%)
      -webkit-filter: grayscale(100%)

  #nav
    color: $color-accent-1
    letter-spacing: .01em
    font-weight: 200
    font-style: normal
    font-size: .8rem

    ul
      margin: 0
      padding: 0
      list-style-type: none
      line-height: 15px

      a
        margin-right: 15px
        color: $color-accent-1

      a:hover
        underline(5px, $color-accent-1)

      li
        display: inline-block
        margin-right: 15px
        border-right: 1px dotted
        border-color: $color-accent-1
        vertical-align: middle

      .icon
        display: none

      li:last-child
        margin-right: 0
        border-right: 0

        a
          margin-right: 0

      // Language switcher styles
      li.lang-switch
        position: relative
        display: inline-block
        border-right: 1px dotted $color-accent-1

        a
          display: flex
          align-items: center
          gap: 5px

          .lang-code
            font-size: 0.7rem
            font-weight: 600

        .lang-dropdown
          opacity: 0
          visibility: hidden
          transform: translateY(-10px)
          transition: all 0.2s ease-in-out
          position: absolute
          top: 100%
          right: 0
          margin-top: 5px
          padding: 5px 0
          min-width: 100px
          background: $color-background
          border: 1px solid $color-border
          border-radius: 4px
          box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15)
          z-index: 1000

          li
            display: block
            margin: 0
            padding: 0
            border-right: none

            a
              display: block
              padding: 8px 15px
              margin: 0
              color: $color-text
              font-size: 0.8rem
              white-space: nowrap
              transition: background 0.15s ease

              &:hover
                background: rgba($color-accent-1, 0.1)
                text-decoration: none

              &.active
                color: $color-accent-1
                font-weight: 600

        &:hover
          .lang-dropdown
            opacity: 1
            visibility: visible
            transform: translateY(0)

        // Support for click toggle
        .lang-dropdown.show
          opacity: 1
          visibility: visible
          transform: translateY(0)

// Language switcher for post pages (desktop)
#header-post
  #nav
    .lang-switch
      position: relative
      display: inline-block

      a
        display: flex
        align-items: center
        gap: 5px

        .lang-code
          font-size: 0.7rem
          font-weight: 600
          color: $color-accent-1

      .lang-dropdown
        display: none
        position: absolute
        top: 100%
        right: 0
        margin-top: 5px
        padding: 5px 0
        min-width: 100px
        background: $color-background
        border: 1px solid $color-border
        border-radius: 4px
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15)
        z-index: 1000

        li
          display: block
          margin: 0
          padding: 0
          border-right: none

          a
            display: block
            padding: 8px 15px
            margin: 0
            color: $color-text
            font-size: 0.8rem
            white-space: nowrap

            &:hover
              background: rgba($color-accent-1, 0.1)
              text-decoration: none

            &.active
              color: $color-accent-1
              font-weight: 600

      &:hover
        .lang-dropdown
          display: block

// Mobile language switcher
#footer-post
  #actions-footer
    #lang-switch-mobile
      font-size: 0.8rem
      
      i
        margin-right: 3px

if $logo-grayout
  #header:hover
    #logo
      filter: none
      -webkit-filter: none

@media screen and (max-width: 480px)
  #header #title
    display: table
    margin-right: 5rem
    min-height: $logo-height
    h1
      display: table-cell
      vertical-align: middle

  #header #nav
    ul
      a:hover
        background: none

      li
        display: none
        border-right: 0

      li.icon
        position: absolute
        top: 77px
        right: 1rem
        display: inline-block
        text-align: center

    ul.responsive
      li
        display: block

      li.lang-switch
        .lang-dropdown
          display: block
          position: static
          margin-top: 10px
          border: none
          box-shadow: none
          background: transparent

          li
            padding: 0
            display: block

            a
              padding: 5px 0

    ul
      a[aria-label="Menu"]
        display: inline-block
        min-width: 48px
        min-height: 48px

    li:not(:first-child)
      padding-top: 1rem
      padding-left: $logo-width + 20px
      font-size: 1rem
